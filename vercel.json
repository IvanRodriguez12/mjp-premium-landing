{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.mjpcontable.com.ar" }],
      "destination": "https://mjpcontable.com.ar/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mjp-premium-landing.vercel.app" }],
      "destination": "https://mjpcontable.com.ar/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "estudio-contable-mjp.vercel.app" }],
      "destination": "https://mjpcontable.com.ar/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}